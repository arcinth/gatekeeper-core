# Copy to .env and adjust for local docker-compose usage.

DB_NAME=gatekeeper
DB_USERNAME=gatekeeper
DB_PASSWORD=gatekeeper
DB_PORT=5433

SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

JWT_SECRET=local-development-secret-key-change-me-in-production-please-0123456789

BOOTSTRAP_ADMIN_EMAIL=admin@gatekeeper.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

CORS_ALLOWED_ORIGINS=http://localhost:5173

# GitHub App integration - optional, all blank/zero by default.
# GITHUB_APP_ID=
# Required for the "Connect GitHub" button - the App's public URL slug, e.g.
# "gatekeeper-core" from https://github.com/apps/gatekeeper-core. Without
# this, GateKeeper reports "The GitHub App is not configured" even if
# GITHUB_APP_ID and the private key are already set.
# GITHUB_APP_SLUG=
# GITHUB_WEBHOOK_SECRET=
# Container-side path (docker-compose mounts ./secrets at /secrets) - see secrets/README.md.
# GITHUB_APP_PRIVATE_KEY_PATH=/secrets/github-app-private-key.pem
